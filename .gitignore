# KiCad source artifacts are intentionally tracked.
# Ignore transient KiCad/editor files.
*.kicad_prl
*.kicad_prl-bak
*.kicad_pcb-bak
*.kicad_sch-bak
~*.lck
*.lck
*~
*.swp
*.swo
.DS_Store

# Local/private automation and scratch files are not public repository artifacts.
scripts/
tools/
private/
.history/
archive/
packages/
build/
dist/
.output/
__pycache__/
*.pyc
*.pyo
*.pyd

# Keep generated/private script source out of this public hardware repo.
*.py
*.sh
*.bash
*.zsh
*.ps1
*.bat
*.cmd
*.js
*.ts

# Local KiCad working directories
**/work/
